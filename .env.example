# === S3 (RustFS) Konfiguration ===
S3_API_PORT=9000
S3_CONSOLE_PORT=9001
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_BUCKET=hek-net-icons
S3_ENDPOINT=http://rustfs:9000

# === Frontend (PHP) Konfiguration ===
# Der Port, unter dem das PHP-Frontend erreichbar ist
FRONTEND_PORT=8000

# Docker Host Verbindung (für Docker-Modul)
# Linux: unix:///var/run/docker.sock
# Windows (Docker Desktop TCP): tcp://host.docker.internal:2375
DOCKER_HOST=unix:///var/run/docker.sock
